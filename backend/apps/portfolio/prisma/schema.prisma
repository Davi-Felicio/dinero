generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("PORTFOLIO_DATABASE_URL")
}

model Asset {
  id        String   @id @default(uuid())
  ticker    String   @unique
  name      String
  type      String
  currency  String   @default("BRL")
  logoUrl   String?  @map("logo_url")
  sector    String?
  createdAt DateTime @default(now()) @map("created_at")

  portfolioAssets PortfolioAsset[]
  transactions    PortfolioTransaction[]

  @@map("assets")
}

model PortfolioAsset {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  assetId      String   @map("asset_id")
  quantity     Decimal
  averagePrice Decimal  @map("average_price")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id])

  @@unique([userId, assetId])
  @@map("portfolio_assets")
}

model PortfolioTransaction {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  assetId       String   @map("asset_id")
  type          String
  quantity      Decimal
  unitPrice     Decimal  @map("unit_price")
  costs         Decimal  @default(0)
  totalAmount   Decimal  @map("total_amount")
  operationDate DateTime @map("operation_date")
  createdAt     DateTime @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([userId, operationDate])
  @@index([assetId])
  @@map("portfolio_transactions")
}
