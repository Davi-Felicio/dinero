{
  "name": "dinero-backend",
  "version": "0.0.1",
  "description": "Dinero - Personal Finance Management App Backend",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build:identity": "nest build identity",
    "build:financial": "nest build financial",
    "build:portfolio": "nest build portfolio",
    "build:openfinance": "nest build openfinance",
    "format": "prettier --write \"{apps,libs}/**/*.ts\"",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "start:identity": "nest start identity --watch",
    "start:financial": "nest start financial --watch",
    "start:portfolio": "nest start portfolio --watch",
    "start:openfinance": "nest start openfinance --watch",
    "start:all": "concurrently \"npm run start:identity\" \"npm run start:financial\" \"npm run start:portfolio\" \"npm run start:openfinance\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prisma:identity:migrate": "prisma migrate dev --schema=apps/identity/prisma/schema.prisma",
    "prisma:identity:generate": "prisma generate --schema=apps/identity/prisma/schema.prisma",
    "prisma:identity:studio": "prisma studio --schema=apps/identity/prisma/schema.prisma",
    "prisma:financial:migrate": "prisma migrate dev --schema=apps/financial/prisma/schema.prisma",
    "prisma:financial:generate": "prisma generate --schema=apps/financial/prisma/schema.prisma",
    "prisma:financial:studio": "prisma studio --schema=apps/financial/prisma/schema.prisma",
    "prisma:portfolio:migrate": "prisma migrate dev --schema=apps/portfolio/prisma/schema.prisma",
    "prisma:portfolio:generate": "prisma generate --schema=apps/portfolio/prisma/schema.prisma",
    "prisma:portfolio:studio": "prisma studio --schema=apps/portfolio/prisma/schema.prisma",
    "prisma:openfinance:migrate": "prisma migrate dev --schema=apps/openfinance/prisma/schema.prisma",
    "prisma:openfinance:generate": "prisma generate --schema=apps/openfinance/prisma/schema.prisma",
    "prisma:openfinance:studio": "prisma studio --schema=apps/openfinance/prisma/schema.prisma",
    "prisma:generate:all": "npm run prisma:identity:generate && npm run prisma:financial:generate && npm run prisma:portfolio:generate && npm run prisma:openfinance:generate",
    "prisma:migrate:all": "npm run prisma:identity:migrate && npm run prisma:financial:migrate && npm run prisma:portfolio:migrate && npm run prisma:openfinance:migrate"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "prisma": "^6.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@dinero/shared(|/.*)$": "<rootDir>/libs/shared/src/$1"
    }
  }
}
