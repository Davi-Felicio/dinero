{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/identity/src",
  "monorepo": true,
  "root": "apps/identity",
  "compilerOptions": {
    "tsConfigPath": "apps/identity/tsconfig.app.json"
  },
  "projects": {
    "identity": {
      "type": "application",
      "root": "apps/identity",
      "entryFile": "main",
      "sourceRoot": "apps/identity/src",
      "compilerOptions": {
        "tsConfigPath": "apps/identity/tsconfig.app.json",
        "assets": [
          {
            "include": "../prisma/generated/**/*",
            "outDir": "dist/apps/identity/apps/identity/prisma"
          }
        ],
        "watchAssets": true
      }
    },
    "financial": {
      "type": "application",
      "root": "apps/financial",
      "entryFile": "main",
      "sourceRoot": "apps/financial/src",
      "compilerOptions": {
        "tsConfigPath": "apps/financial/tsconfig.app.json",
        "assets": [
          {
            "include": "../prisma/generated/**/*",
            "outDir": "dist/apps/financial/apps/financial/prisma"
          }
        ],
        "watchAssets": true
      }
    },
    "portfolio": {
      "type": "application",
      "root": "apps/portfolio",
      "entryFile": "main",
      "sourceRoot": "apps/portfolio/src",
      "compilerOptions": {
        "tsConfigPath": "apps/portfolio/tsconfig.app.json",
        "assets": [
          {
            "include": "../prisma/generated/**/*",
            "outDir": "dist/apps/portfolio/apps/portfolio/prisma"
          }
        ],
        "watchAssets": true
      }
    },
    "openfinance": {
      "type": "application",
      "root": "apps/openfinance",
      "entryFile": "main",
      "sourceRoot": "apps/openfinance/src",
      "compilerOptions": {
        "tsConfigPath": "apps/openfinance/tsconfig.app.json",
        "assets": [
          {
            "include": "../prisma/generated/**/*",
            "outDir": "dist/apps/openfinance/apps/openfinance/prisma"
          }
        ],
        "watchAssets": true
      }
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    }
  }
}
